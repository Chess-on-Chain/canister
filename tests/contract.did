type Match = record {
  id : text;
  fen : text;
  moves : vec nat16;
  timer : opt nat64;
  winner : text;
  black_player : principal;
  white_player : principal;
  is_white_turn : bool;
};
type MatchResult = record {
  id : text;
  fen : text;
  moves : vec nat16;
  winner : text;
  black_player : User;
  white_player : User;
};
type MatchResultHistory = record {
  id : text;
  fen : text;
  moves : vec nat16;
  winner : text;
  black_player : principal;
  white_player : principal;
};
type User = record {
  id : principal;
  win : nat16;
  draw : nat16;
  lost : nat16;
  is_banned : bool;
};
service : () -> {
  accept_ownership : () -> ();
  add_match : (principal, principal) -> (record { text; Match });
  add_match_move : (text, nat16) -> (Match);
  ban : (principal) -> ();
  get_histories : (principal, nat16, nat16) -> (vec MatchResultHistory) query;
  get_match : (text) -> (MatchResult) query;
  get_user : (principal) -> (opt User) query;
  initialize : (principal, principal) -> ();
  transfer_ownership : (principal) -> ();
  unban : (principal) -> ();
}
