type Match = record {
  id : text;
  fen : text;
  moves : vec nat16;
  timer : opt nat64;
  white_player : User;
  black_player : User;
  winner : text;
  is_white_turn : bool;
};
type User = record {
  id : principal;
  win : nat16;
  username : opt text;
  draw : nat16;
  lost : nat16;
  fullname : opt text;
  is_banned : bool;
};
service : () -> {
  accept_ownership : () -> ();
  add_match : (principal, principal) -> (record { text; Match });
  add_match_move : (text, nat16) -> (Match);
  ban : (principal) -> ();
  get_match : (text) -> (Match) query;
  get_user : (principal) -> (opt User) query;
  initialize : (principal, principal) -> ();
  set_name : (text) -> ();
  set_username : (text) -> ();
  transfer_ownership : (principal) -> ();
  unban : (principal) -> ();
}
